#!/usr/bin/env bash
# vtesItaly.Draft — pre-commit gate.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Runs Prettier (check only), ESLint, and the test suite. Fails fast.

set -e

if [ -z "$(command -v npx)" ]; then
  echo "pre-commit: npx not found — skipping JS checks" >&2
  exit 0
fi

if [ ! -d node_modules ]; then
  echo "pre-commit: node_modules missing — run 'npm install' first" >&2
  exit 1
fi

echo "pre-commit: prettier --check"
npm run --silent format:check

echo "pre-commit: eslint"
npm run --silent lint

if command -v python >/dev/null 2>&1 && python -m ruff --version >/dev/null 2>&1; then
  echo "pre-commit: ruff check"
  python -m ruff check scripts/ tests/
  echo "pre-commit: ruff format --check"
  python -m ruff format --check scripts/ tests/
else
  echo "pre-commit: ruff not installed — skipping Python lint" >&2
fi

echo "pre-commit: tests (node + python)"
npm test --silent
